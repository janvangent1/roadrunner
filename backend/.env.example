DATABASE_URL=postgresql://roadrunner:roadrunner@postgres:5432/roadrunner
REDIS_URL=redis://redis:6379
JWT_SECRET=<generate with openssl rand -hex 32>
JWT_REFRESH_SECRET=<generate with openssl rand -hex 32>
# Generate with: node -e "const {aead,binaryInsecure}=require('tink-crypto');aead.register();aead.generateNew(aead.aes256GcmKeyTemplate()).then(h=>console.log(Buffer.from(binaryInsecure.serializeKeyset(h)).toString('base64')))"
TINK_KEYSET_JSON=<base64 encoded binary Tink AES-256-GCM keyset>
GOOGLE_CLIENT_ID=<from Google Cloud Console>
PORT=3000
# Play Integrity: Android package name for token decoding (must match app's applicationId)
ANDROID_PACKAGE_NAME=com.roadrunner.app
